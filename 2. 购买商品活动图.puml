@startuml 购买商品活动图
skinparam backgroundColor white
skinparam handwritten false
skinparam defaultFontName "Microsoft YaHei"

title 购买商品活动图

start
:买家浏览商品列表;
:选择感兴趣的商品;
:查看商品详情;

if (商品是否可购买?) then (是)
  :点击"购买"按钮;
  :系统跳转到订单页面;
  :填写交易信息(收货地址等);
  :确认订单信息;
  
  repeat
    :系统验证账户余额;
    
    if (余额是否充足?) then (充足)
      :冻结支付金额;
      :创建订单记录;
      :系统标记商品为预订状态;
      :系统通知卖家有新订单;
      
      fork
        :买家等待卖家确认;
      fork again
        :卖家收到通知;
        :卖家确认订单;
        
        if (卖家是否接受订单?) then (接受)
          :更新订单状态为已确认;
          :系统通知买家订单已确认;
          
          if (是否当面交易?) then (是)
            :买家与卖家约定交易地点和时间;
            :当面交易完成;
            :买家确认收货;
          else (否)
            :卖家安排发货;
            :输入物流信息;
            :系统通知买家已发货;
            :买家收到商品;
            :买家确认收货;
          endif
          
          :系统将冻结金额转给卖家;
          :更新订单状态为已完成;
          :更新商品状态为已售出;
        else (拒绝)
          :更新订单状态为已取消;
          :解冻买家支付金额;
          :系统通知买家订单被拒绝;
        endif
      end fork
      break
      
    else (不足)
      :系统提示"余额不足";
      :提供充值选项;
      
      if (是否选择充值?) then (是)
        :跳转到充值页面;
        :完成充值;
      else (否)
        :取消订单;
        break
      endif
    endif
  repeat while (余额不足且选择充值)
  
else (否)
  :系统提示"商品已售出";
endif

stop
@enduml