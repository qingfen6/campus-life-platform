@startuml 接取悬赏活动图
skinparam backgroundColor white
skinparam handwritten false
skinparam defaultFontName "Microsoft YaHei"

title 接取悬赏活动图

start
:用户浏览悬赏任务列表;
:选择感兴趣的悬赏任务;
:查看悬赏任务详情;

if (任务是否可接取?) then (是)
  :点击"接取"按钮;
  :系统显示接单申请表单;
  :填写接单申请说明;
  :提交接单申请;
  :系统通知发布者有新接单;
  
  fork
    :等待发布者审核;
  fork again
    :发布者收到通知;
    :发布者查看申请详情;
    
    if (发布者是否接受?) then (接受)
      :更新申请状态为接受;
      :更新任务状态为进行中;
      :系统通知接单者申请通过;
      :接单者执行任务;
      
      repeat
        :提交任务成果;
        :发布者验收任务;
        
        if (验收是否通过?) then (通过)
          :更新任务状态为已完成;
          :系统解冻悬赏金额;
          :转账给接单者;
          :接单者收到悬赏金额;
          break
        else (不通过)
          :要求修改任务成果;
          :接单者修改任务成果;
        endif
      repeat while (需要继续修改?)
      
    else (拒绝)
      :更新申请状态为拒绝;
      :系统通知接单者被拒绝;
    endif
  end fork
  
else (否)
  :系统提示"任务已不可接取";
endif

stop
@enduml